# ---------------------------------------------------------------------------
# DSVV News — .gitignore  (Python / Flask / MongoDB)
# ---------------------------------------------------------------------------

# --- Secrets ---------------------------------------------------------------
.env
.env.*
!.env.example

# --- Python bytecode / build artefacts -------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
build/
dist/
.eggs/
pip-log.txt
pip-delete-this-directory.txt

# --- Virtual environments --------------------------------------------------
venv/
.venv/
env/
.env/
ENV/

# --- Flask runtime / local data --------------------------------------------
instance/
uploads/

# --- Tooling caches --------------------------------------------------------
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/

# --- Editors / IDEs --------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# --- OS junk ---------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# --- Node (only if JS tooling is ever added) -------------------------------
node_modules/
package.json
package-lock.json

# --- Scratch / debug dumps -------------------------------------------------
_*.txt
_*.html
*.log
