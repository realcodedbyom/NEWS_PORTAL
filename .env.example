# Flask
FLASK_APP=wsgi.py
FLASK_ENV=development
FLASK_CONFIG=development
SECRET_KEY=change-me-in-production

# MongoDB
# Pick ONE:
#  - Local:    mongodb://localhost:27017/dsvv_news
#  - Atlas:    mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/dsvv_news?retryWrites=true&w=majority
MONGODB_DB=dsvv_news
MONGODB_HOST=mongodb://localhost:27017/dsvv_news

# JWT
JWT_SECRET_KEY=change-me-too
JWT_ACCESS_TOKEN_EXPIRES_MIN=60
JWT_REFRESH_TOKEN_EXPIRES_DAYS=14

# Media
UPLOAD_FOLDER=./uploads
MAX_CONTENT_LENGTH_MB=25

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5000

# Scheduler
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_SECONDS=60

# Bootstrap admin (used by scripts/seed.py on first run)
ADMIN_EMAIL=admin@dsvv.ac.in
ADMIN_PASSWORD=ChangeMe123!
ADMIN_NAME=DSVV Admin
